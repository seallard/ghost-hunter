# Clerk — get keys from https://dashboard.clerk.com (Development instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk's hosted components send users
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Postgres — local default matches docker-compose.yml; Railway injects via the Postgres plugin
DATABASE_URL=postgres://ghost:ghost@localhost:5432/ghost_hunter

# Object storage — Railway bucket for PDF uploads. Pull from the bucket's "Connect" tab.
# Local dev does not require these set; uploads will 500 without them.
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=ghost-hunter-resumes
STORAGE_REGION=us-east-1
